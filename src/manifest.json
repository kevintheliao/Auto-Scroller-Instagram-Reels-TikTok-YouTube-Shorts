{
  "manifest_version": 3,
  "name": "Auto Scroller — Instagram Reels, TikTok & YouTube Shorts",
  "version": "2.1.3",
  "description": "Auto-scroll Instagram Reels, TikTok videos & YouTube Shorts hands-free. Plays the next video automatically when one ends. Control with simple hotkeys.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*",
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ]
    },
    {
      "matches": [
        "https://www.tiktok.com/*"
      ],
      "js": [
        "main-world.js"
      ],
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icon48.png"
      ],
      "matches": [
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*",
        "https://www.youtube.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}